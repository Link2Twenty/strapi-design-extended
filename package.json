{
  "name": "strapi-design-extended",
  "version": "0.0.9",
  "type": "module",
  "description": "Build upon the @strapi/design-system to add a few more components",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "echo \"Error: no test specified\" && exit 1",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "deploy-storybook": "gh-pages -d storybook-static",
    "postversion": "git push && git push --tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Link2Twenty/strapi-design-extended.git"
  },
  "keywords": [
    "strapi",
    "design",
    "theme"
  ],
  "author": "Andrew Bone <AndrewB05+strapi@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Link2Twenty/strapi-design-extended/issues"
  },
  "homepage": "https://github.com/Link2Twenty/strapi-design-extended#readme",
  "peerDependencies": {
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@radix-ui/react-toolbar": "^1.1.0",
    "@strapi/design-system": "^2.2.0",
    "react": "^17.0.0 || ^18.0.0",
    "react-dom": "^17.0.0 || ^18.0.0",
    "styled-components": "^5.2.1 || ^6.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@strapi/design-system": "^2.2.1",
    "@strapi/icons": "^2.2.1",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@radix-ui/react-toolbar": "^1.1.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "gh-pages": "^6.3.0",
    "playwright": "^1.61.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sass": "^1.101.0",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9"
